@startuml AI_Cognitive_Architecture
skinparam node {
    BackgroundColor #f4f6f8
    BorderColor #a2b4c6
}

actor "LLM / AI Agent" as Agent
actor "TPP App" as App

node "External Interface" {
    [Nebras MCP Server] <<Tool Exposer>>
    [API Gateway] <<DPoP Validator>>
}

node "Agentive Platform (OpenShift)" {
    
    component "Agent Gateway\n(Spring Cloud Gateway)" as gateway
    
    node "Harness Layer" {
        component "Security LLM\n<<Streaming DLP>>" as dlp #lightcoral
        component "Agent Scoper\n<<PII Hashing>>" as scoper #lightyellow
    }
    
    node "Cognitive Layer" {
        component "Harness Orchestrator\n<<Task Parser>>" as harness
        component "Agent Execution\n<<Iterative Loop>>" as execLoop
        component "Mixture of Experts Router" as router
        database "Semantic Cache\n<<pgvector>>" as cache
        component "Cognitive Circuit Breaker" as cb #orange
        component "SLM (Fast Intent)" as slm #lightblue
        component "LLM (Deep Reasoning)" as llm #lightblue
        component "Temporal Workflow\n<<e.g. TPP Admission>>" as temp
    }
    
    node "Memory Banks" {
        database "Agent State DB" as memory
    }
    
    node "Security Fabric" {
        component "Istio Mesh" as istio
        component "Hardware Kill Switch" as killswitch #red
    }
}

gateway --> dlp : Raw Request
dlp --> scoper : Safe Request
scoper --> harness : Hashed Request
harness --> execLoop : Structured Tasks
execLoop --> router : Task Iteration
router <--> cache : Check Intent
router --> cb : Route Request
cb --> slm : Simple Task
cb --> llm : Complex Task
cb --> temp : Fallback (Rules Engine)

slm --> temp : Intent Execution
llm --> temp : Intent Execution

temp --> execLoop : Result/Signal
execLoop --> memory : Update State
killswitch ..> istio : Revokes SPIFFE ID

@enduml
