@startuml C4_Component
skinparam component {
    BackgroundColor #85bbf0
}

package "Agentive Backend Core" {
    component "AgentFteWebSocketHandler\n<<Spring WebSockets>>" as WSHandler
    component "AgentIngestionKafkaListener\n<<Spring Kafka>>" as KafkaListener
    component "FteHarnessCoordinator\n<<Agent Orchestrator>>" as Coordinator
    component "FteCostOptimizer\n<<Economics>>" as Economics
    component "ModelAgnosticHarness\n<<Temporal Workflows>>" as Harness
    
    package "12-Factor WebClient Ports" {
        component "WebClientGithubAdapter" as GithubAdapter
        component "WebClientJiraAdapter" as JiraAdapter
    }
}

database "Memory Bank\n<<MongoDB>>" as MemoryBank
queue "CBUAE OpenFinance Events" as KafkaTopic

WSHandler --> Coordinator : Dispatches Chat Tasks
KafkaListener --> Coordinator : Autonomous Ingestion
Coordinator --> Economics : authorizeAndConsume(Tokens)
Coordinator --> Harness : executeWithMemory(Session)
Coordinator --> MemoryBank : Persists State
Harness --> GithubAdapter : readPrdFromRepo
Harness --> JiraAdapter : createJiraTicket

KafkaTopic --> KafkaListener : Consumes webhook

@enduml
