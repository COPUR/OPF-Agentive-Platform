@startuml Deployment_Sandbox
skinparam node {
    BackgroundColor #f4f6f8
    BorderColor #a2b4c6
}
skinparam component {
    BackgroundColor #ffffff
}

node "OpenShift Cluster" as k8s {
    
    component "Istio Ingress Gateway" as ingress

    node "Namespace: opf-sandbox" {
        
        node "Pod: Keycloak" {
            component "Envoy Proxy\n<<Sidecar>>" as e1 #lightgrey
            component "Keycloak" as kc
            e1 <-> kc
        }
        
        node "Pod: MongoDB" {
            component "Envoy Proxy\n<<Sidecar>>" as e2 #lightgrey
            database "MongoDB" as mongo
            e2 <-> mongo
        }
        
        node "Pod: Temporal" {
            component "Envoy Proxy\n<<Sidecar>>" as e3 #lightgrey
            component "Temporal Server" as temp
            e3 <-> temp
        }
        
        node "Pod: Postgres Vector" {
            component "Envoy Proxy\n<<Sidecar>>" as e4 #lightgrey
            database "PostgreSQL\n<<pgvector>>" as pg
            e4 <-> pg
        }
        
        node "Pod: Kafka" {
            component "Envoy Proxy\n<<Sidecar>>" as e5 #lightgrey
            component "Kafka Broker" as kafka
            e5 <-> kafka
        }
    }
    
    ingress --> e1 : /auth routing
    e1 --> e2 : Stores Party Data
    e3 --> e4 : Stores Workflow State
    e3 --> e5 : Task Queues / Outbox
}
@enduml
