@startuml Deployment_Sandbox
skinparam node {
    BackgroundColor #f4f6f8
    BorderColor #a2b4c6
}
skinparam component {
    BackgroundColor #ffffff
}

node "OpenShift Cluster" as k8s {
    
    component "Kong Mesh Ingress Gateway" as ingress

    node "Namespace: opf-sandbox" {
        
        node "Pod: Keycloak" {
            component "Kuma Data Plane\n<<Envoy + OPA Policies>>" as e1 #lightgrey
            component "Keycloak" as kc
            e1 <-> kc
        }
        
        node "Pod: MongoDB" {
            component "Kuma Data Plane\n<<Envoy + OPA Policies>>" as e2 #lightgrey
            database "MongoDB" as mongo
            e2 <-> mongo
        }
        
        node "Pod: Temporal" {
            component "Kuma Data Plane\n<<Envoy + OPA Policies>>" as e3 #lightgrey
            component "Temporal Server" as temp
            e3 <-> temp
        }
        
        node "Pod: Postgres Vector" {
            component "Kuma Data Plane\n<<Envoy + OPA Policies>>" as e4 #lightgrey
            database "PostgreSQL\n<<pgvector>>" as pg
            e4 <-> pg
        }
        
        node "Pod: Kafka" {
            component "Kuma Data Plane\n<<Envoy + OPA Policies>>" as e5 #lightgrey
            component "Kafka Broker" as kafka
            e5 <-> kafka
        }
        node "Pod: React Portal" {
            component "Kuma Data Plane\n<<Envoy + OPA Policies>>" as e6 #lightgrey
            component "frontend-x-bank-souq" as portal
            e6 <-> portal
        }
        
        node "Pod: Kong AI Gateway (HA ReplicaSet)" {
            component "Kuma Data Plane\n<<Envoy + OPA Policies>>" as ek #lightgrey
            component "Kong Gateway\n<<DB-less>>" as kong
            ek <-> kong
        }
        
        node "Pod: MCP Server" {
            component "Kuma Data Plane\n<<Envoy + OPA Policies>>" as e7 #lightgrey
            component "opf-nebras-mcp-server" as mcp
            e7 <-> mcp
        }
    }
    
    ingress --> e6 : /portal routing
    ingress --> ek : /ai-intent routing
    ek --> e7 : Routes to MCP
    ek --> e3 : Routes to Temporal
    ingress --> e1 : /auth routing
    e1 --> e2 : Stores Party Data
    e3 --> e4 : Stores Workflow State
    e3 --> e5 : Task Queues / Outbox
}
@enduml
